# Google Sheets API
GOOGLE_SHEET_CREDENTIALS_PATH=config/client_secret_....json
SPREADSHEET_NAME=Your Google Sheet Name
SHEET_TAB_NAME=Sheet1
EMAIL_COLUMN_NAME=email

# CSV Dataset
DATASET_PATH=config/dataset.csv
DATASET_EMAIL_COLUMN=email

# SMTP Gmail
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Canva Invitation Email
EMAIL_SUBJECT=You're invited to Canva Pro!
EMAIL_BODY=Hi, you've been invited to join Canva Pro. Click here to accept your invitation.

# Polling
POLL_INTERVAL_SECONDS=60
